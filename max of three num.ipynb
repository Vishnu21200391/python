    "x = int(input())\n",
    "y = int(input())\n",
    "z = int(input())\n",
    "\n",
    "def max(x,y,z):\n",
    "    if x>y:\n",
    "        print(\"x is greater\")\n",
    "    elif y>z:\n",
    "        print(\"y is greater\")\n",
    "    elif z>x:\n",
    "        print(\"z is greater\")\n",
    "    return x,y,z\n",
    "\n",
    "print(max(x,y,z))"
   ]
