   "source": [
    "x = int(input(\"enter any number:\"))\n",
    "\n",
    "def spl_num(x):\n",
    "    y = str(x)\n",
    "    y.split()\n",
    "    a = int(y[0]) + int(y[1])\n",
    "    b = int(y[0]) * int(y[1])\n",
    "    c = a + b\n",
    "    if c==x:\n",
    "        print(\"Given num is spl\")\n",
    "    else:\n",
    "        print(\"not spl\")\n",
    "\n",
    "spl_num(x)"
   ]
